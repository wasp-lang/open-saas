---
import VersionSelect from "starlight-versions/components/VersionSelect.astro";
import blogConfig from "virtual:starlight-blog/config";
import config from "virtual:starlight/user-config";
import { logos } from "virtual:starlight/user-images";

const href = Astro.site;
const { siteTitle } = Astro.locals.starlightRoute;

// The blog is not versioned, so the version select makes no sense there.
const isBlogRoute = Astro.url.pathname.startsWith("/blog/");

const navItemClasses =
  "ml-4 h-full gap-4 self-center border-e border-e-(--sl-color-gray-5) pe-4 min-[50rem]:flex min-[50rem]:items-center";
const navLinkClasses =
  "font-semibold text-(--sl-color-white) no-underline hover:text-(--sl-color-text-accent)";
const logoClasses =
  "h-[calc(var(--sl-nav-height)_-_2*var(--sl-nav-pad-y))] w-auto max-w-full object-contain object-[0_50%]";
---

<a
  {href}
  class="sl-flex max-w-full items-center justify-self-start gap-(--sl-nav-gap) overflow-hidden border-e border-e-(--sl-color-gray-5) pe-4 whitespace-nowrap no-underline"
>
  {
    config.logo && logos.dark && (
      <>
        <img
          class:list={[
            logoClasses,
            { "light:sl-hidden print:hidden": !("src" in config.logo) },
          ]}
          alt={config.logo.alt}
          src={logos.dark.src}
          width={logos.dark.width}
          height={logos.dark.height}
        />
        {/* Show light alternate if a user configure both light and dark logos. */}
        {!("src" in config.logo) && (
          <img
            class:list={[logoClasses, "dark:sl-hidden print:block"]}
            alt={config.logo.alt}
            src={logos.light?.src}
            width={logos.light?.width}
            height={logos.light?.height}
          />
        )}
      </>
    )
  }
  <span
    class:list={{ "sr-only": config.logo?.replacesTitle }}
    class="font-semibold text-(length:--sl-text-h4) text-(--sl-color-white) hover:text-(--sl-color-text-accent)"
  >
    {siteTitle}
  </span>
</a>
<div class={navItemClasses}>
  <a href="/" class={navLinkClasses}>Docs</a>
</div>
{
  !isBlogRoute && (
    <div class={navItemClasses}>
      <VersionSelect />
    </div>
  )
}
<div class={navItemClasses}>
  <a href="/blog/" class={navLinkClasses}>{blogConfig.title}</a>
</div>
