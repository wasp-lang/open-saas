# All client-side env vars must start with REACT_APP_ https://wasp.sh/docs/project/env-vars

# See https://docs.opensaas.sh/guides/analytics/#google-analytics
REACT_APP_GOOGLE_ANALYTICS_ID=G-...

# Only needed if using Paddle as your payment processor. Paddle checkout runs in the
# browser via Paddle.js, so it needs the public client-side token.
# Get it at Paddle Dashboard -> Developer Tools -> Authentication (starts with `test_` in sandbox).
REACT_APP_PADDLE_CLIENT_TOKEN=test_...
# Set to "true" for Paddle's sandbox, "false" (or unset) for production. Keep in sync with PADDLE_SANDBOX_MODE.
REACT_APP_PADDLE_SANDBOX_MODE=true
