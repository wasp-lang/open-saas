datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  email                     String?         @unique
  username                  String?         @unique
  isAdmin                   Boolean         @default(false)

  paymentProcessorUserId    String?         @unique
  lemonSqueezyCustomerPortalUrl String?
  subscriptionStatus        String?         // 'active', 'cancel_at_period_end', 'past_due', 'deleted'
  subscriptionPlan          String?         // 'free', 'starter', 'professional', 'enterprise'
  datePaid                  DateTime?
  credits                   Int             @default(5)

  deals                     Deal[]
  underwritingRuns          UnderwritingRun[]
  loanScenarios             LoanScenario[]
  documentExtractions       DocumentExtraction[]
  contactFormMessages       ContactFormMessage[]
  files                     File[]
}

model Deal {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  name                      String
  address                   String?
  city                      String?
  state                     String?
  assetClass                String          // 'multifamily', 'office', 'industrial', 'retail', 'hotel', 'mixed-use'
  units                     Int?
  squareFeet                Int?
  yearBuilt                 Int?
  purchasePrice             Float
  notes                     String?

  underwritingRuns          UnderwritingRun[]
  loanScenarios             LoanScenario[]
  documentExtractions       DocumentExtraction[]
}

model UnderwritingRun {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  deal                      Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId                    String?

  inputs                    String          // JSON: purchase price, NOI, rent growth, cap rate, hold period, etc.
  outputs                   String          // JSON: IRR, equity multiple, cash-on-cash, 10-yr cash flow, sensitivity
  summary                   String          // AI-generated executive summary
}

model LoanScenario {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  deal                      Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId                    String?

  inputs                    String          // JSON: purchase price, NOI, rate, term, amort, DSCR target, LTV cap
  outputs                   String          // JSON: loan amount, DSCR, LTV, LTC, debt yield, payment, lender comparison
  summary                   String          // AI-generated debt memo
}

model DocumentExtraction {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  deal                      Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId                    String?

  documentType              String          // 't12', 'rent_roll', 'om', 'loan_quote'
  sourceFileName            String
  extracted                 String          // JSON structured output
}

model File {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  name                      String
  type                      String
  s3Key                     String
}

model DailyStats {
  id                               Int             @id @default(autoincrement())
  date                             DateTime        @default(now()) @unique

  totalViews                       Int             @default(0)
  prevDayViewsChangePercent        String          @default("0")
  userCount                        Int             @default(0)
  paidUserCount                    Int             @default(0)
  userDelta                        Int             @default(0)
  paidUserDelta                    Int             @default(0)
  totalRevenue                     Float           @default(0)
  totalProfit                      Float           @default(0)

  sources                          PageViewSource[]
}

model PageViewSource {
  @@id([date, name])
  name                     String
  date                     DateTime        @default(now())

  dailyStats               DailyStats?     @relation(fields: [dailyStatsId], references: [id])
  dailyStatsId             Int?

  visitors                 Int
}

model Logs {
  id                       Int             @id @default(autoincrement())
  createdAt                DateTime        @default(now())

  message                  String
  level                    String
}

model ContactFormMessage {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  content                   String
  isRead                    Boolean         @default(false)
  repliedAt                 DateTime?
}
