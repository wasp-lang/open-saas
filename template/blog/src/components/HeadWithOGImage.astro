---
import Default from "@astrojs/starlight/components/Head.astro";
import {
  BANNER_PATH,
  checkBannerImageExists,
  DEFAULT_BANNER_IMAGE,
  getBannerImageFilename,
} from "./imagePaths";

const bannerImageFileName = getBannerImageFilename({
  path: Astro.locals.starlightRoute.id,
});
const imageExists = checkBannerImageExists({ bannerImageFileName });

// Get the URL of the social media preview image for the current post using its
// route id and replace the path and file extension with `.webp`.
let ogImageUrl = new URL(`${BANNER_PATH}/${DEFAULT_BANNER_IMAGE}`, Astro.site);
if (imageExists) {
  ogImageUrl = new URL(`${BANNER_PATH}/${bannerImageFileName}`, Astro.site);
}
---

<Default><slot /></Default>

<!-- Open Graph images. -->
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:image" content={ogImageUrl} />
