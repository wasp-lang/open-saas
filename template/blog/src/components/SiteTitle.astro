---
/**
 * Overriden component, for more info:
 * @see {@link https://starlight.astro.build/guides/overriding-components/}
 * @see {@link https://starlight.astro.build/reference/overrides/#sitetitle}
 */

import blogConfig from "virtual:starlight-blog/config";
import config from "virtual:starlight/user-config";
import { logos } from "virtual:starlight/user-images";

const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;

const navLinkClass =
  "font-semibold  aria-[current=page]:text-(--sl-color-text-accent) no-underline hover:text-(--sl-color-text-accent) text-(--sl-color-white) border-s border-s-(--sl-color-gray-5) ps-4";

const { pathname } = Astro.url;
const isBlog = pathname.startsWith("/blog/");
---

<a
  href={siteTitleHref}
  class={"site-title sl-flex hover:text-(--sl-color-text-accent)"}
>
  {
    config.logo && logos.dark && (
      <>
        <img
          class:list={{
            "light:sl-hidden print:hidden": !("src" in config.logo),
          }}
          alt={config.logo.alt}
          src={logos.dark.src}
          width={logos.dark.width}
          height={logos.dark.height}
        />
        {/* Show light alternate if a user configure both light and dark logos. */}
        {!("src" in config.logo) && (
          <img
            class="dark:sl-hidden print:block"
            alt={config.logo.alt}
            src={logos.light?.src}
            width={logos.light?.width}
            height={logos.light?.height}
          />
        )}
      </>
    )
  }
  <span class:list={{ "sr-only": config.logo?.replacesTitle }} translate="no">
    {siteTitle}
  </span>
</a>
<nav class="flex items-center justify-start gap-4 mx-4">
  <a aria-current={!isBlog ? "page" : undefined} href="/" class={navLinkClass}
    >Docs</a
  >
  <a
    aria-current={isBlog ? "page" : undefined}
    href="/blog/"
    class={navLinkClass}>{blogConfig.title}</a
  >
</nav>

<style>
  @layer starlight.core {
    .site-title {
      align-items: center;
      gap: var(--sl-nav-gap);
      font-size: var(--sl-text-h4);
      font-weight: 600;
      color: var(--sl-color-white);
      text-decoration: none;
      white-space: nowrap;
      min-width: 0;
    }
    span {
      overflow: hidden;
    }
    img {
      height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
      width: auto;
      max-width: 100%;
      object-fit: contain;
      object-position: 0 50%;
    }
  }
</style>
